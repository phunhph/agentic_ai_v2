# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=agentic_ai
DB_USER=postgres
DB_PASSWORD=your_password

# AI Providers
OPENAI_API_KEY=
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Model configuration
CHAT_MODEL=grok  # Options: grok, gemini, openrouter, openai
REASONING_MODEL=gemini  # Options: groq, gemini, openrouter, openai
EMBEDDING_MODEL=openrouter  # Options: groq, gemini, openrouter, openai

GEMINI_MODEL=gemini/gemini-flash-latest
GROQ_MODEL=groq/llama-3.3-70b-versatile
OPENROUTER_MODEL=openrouter/openai/gpt-oss-20b:free
OPENAI_MODEL=gpt-4o
OPENAI_MINI_MODEL=gpt-4o-mini

# Application
APP_ENV=development
DEBUG=true

# Optional tracing / observability
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=agentic-crm
PHOENIX_PORT=6006
